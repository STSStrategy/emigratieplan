@@ -1443,6 +1443,33 @@
 <script>
 (function () {
 
+  // R3: voorkom dat de pagina mid-page opent.
+  // Oorzaak: de Beslisgids-preview-iframes laadden met een #page-fragment,
+  // waardoor de browser de parent naar het iframe scrolde. We laden nu zonder
+  // fragment en scrollen alleen het iframe zelf, na load.
+  if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
+
+  function scrollBriefFrames() {
+    document.querySelectorAll('.ep-brief-tile__frame iframe[data-page]').forEach(function (f) {
+      function go() {
+        try {
+          var id = f.getAttribute('data-page');
+          var doc = f.contentDocument;
+          var el = doc && doc.getElementById(id);
+          if (el && f.contentWindow) f.contentWindow.scrollTo(0, el.offsetTop);
+        } catch (e) { /* cross-doc of nog niet geladen, negeer */ }
+      }
+      f.addEventListener('load', go);
+      if (f.contentDocument && f.contentDocument.readyState === 'complete') go();
+    });
+  }
+  scrollBriefFrames();
+
+  // Vangnet: bij een verse load zonder hash bovenaan beginnen.
+  window.addEventListener('load', function () {
+    if (!location.hash) window.scrollTo(0, 0);
+  });
+
   // Scroll progress
   var bar = document.getElementById('ep-scroll-progress');
   function onScroll() {
